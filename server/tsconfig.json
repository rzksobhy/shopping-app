{
    "compilerOptions": {
        "target": "es2016",
        "module": "commonjs",
        "rootDir": "./src",
        "outDir": "./dist",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "removeComments": true,
        "importsNotUsedAsValues": "remove",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipDefaultLibCheck": true,
        "skipLibCheck": true
    },
    "include": [
        "./src/"
    ],
    "exclude": []
}
